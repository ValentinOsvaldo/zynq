{
  "name": "@zynq/vue",
  "version": "1.0.4",
  "description": "Synchronize application state with the URL using Vue 3 composables and Vue Router",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@zynq/core": "workspace:*"
  },
  "peerDependencies": {
    "vue": "^3.0.0",
    "vue-router": "^4.0.0"
  },
  "keywords": [
    "vue",
    "vue-router",
    "url-state",
    "sync",
    "query-params",
    "composables"
  ],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.28.2",
  "devDependencies": {
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^17.6.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4",
    "vue": "^3.5.29",
    "vue-router": "^5.0.3"
  }
}
